{
  "_comment": "Policy for MeetingBar. Edited values are picked up on the next detection (no recompile).",

  "meeting_bundle_ids": [
    "com.microsoft.teams2",
    "com.microsoft.teams",
    "us.zoom.xos",
    "com.tinyspeck.slackmacgap",
    "com.cisco.webexmeetingsapp",
    "com.webex.meetingmanager"
  ],

  "meeting_command": "/opt/homebrew/bin/uv run --project /Users/jonathan.glasmeyer/Projects/meeting-transcript meeting",
